# ─────────────────────────────────────────────────────────────────────────────
# Tyvera — .env.local.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the values you need.
# Variables are grouped by what they unlock. The app boots without any of
# them, but certain endpoints / cron jobs / admin paths require specific
# secrets — see the notes under each section.

# ── Database (Turso / libsql) ────────────────────────────────────────────────
#
# Production uses Turso (hosted libsql). Locally, if these are unset the app
# falls back to an in-memory sql.js database — useful for read-only UI work
# but NOT durable: subscriptions, API keys, alert rules reset every restart.
#
# Required for production-like behavior, API-key management, subscription
# persistence, and cron workflows.
#
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# ── Cron protection ──────────────────────────────────────────────────────────
#
# Protects /api/cron/* and /api/verify-payments. Vercel cron sends this in the
# `Authorization: Bearer <CRON_SECRET>` header. Generate a long random value
# and mirror it into Vercel project env for scheduled runs to succeed.
#
# Without it, the cron endpoints refuse to run (by design).
#
CRON_SECRET=generate_a_long_random_value_here

# ── Admin protection ─────────────────────────────────────────────────────────
#
# Protects /api/admin/* routes (data-health, subscription overrides). Set this
# only in environments where someone should be able to hit the admin surface.
#
# Without it, admin endpoints return 401 for every request.
#
ADMIN_SECRET=generate_a_long_random_value_here

# ── Data providers ───────────────────────────────────────────────────────────
#
# TAOSTATS — primary subnet / chain data source.
#   Obtain at: https://dash.taostats.io
#   Used by `npm run fetch-subnets` and server-side enrichment.
#
TAOSTATS_API_KEY=your_taostats_api_key_here

# CoinMarketCap — secondary TAO/USD price + market enrichment.
#   Free-tier key: https://coinmarketcap.com/api/
#   Used as a fallback when CoinGecko is unavailable.
#
CMC_API_KEY=your_coinmarketcap_api_key_here

# TAO.app — holder / validator snapshots.
#   Used by `npm run build-holder-snapshot-tao-app` and validator scripts.
#   Optional; those scripts will no-op without it.
#
TAO_APP_API_KEY=your_tao_app_api_key_here

# ── Chat / AI ────────────────────────────────────────────────────────────────
#
# OpenAI key used by /api/chat (explorer AI). Optional: without it, the chat
# endpoint returns a configuration error but the rest of the app is fine.
#
OPENAI_API_KEY=your_openai_api_key_here

# ── App URLs (usually auto-populated on Vercel) ──────────────────────────────
#
# Used to resolve absolute URLs from server-side code (e.g. internal fetches).
# On Vercel, VERCEL_URL / VERCEL_PROJECT_PRODUCTION_URL are auto-populated.
# For local dev, NEXT_PUBLIC_BASE_URL defaults to http://localhost:3000.
#
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
# APP_URL=https://tyvera.app

# ── Dev stability note ───────────────────────────────────────────────────────
#
# If the dev server shows stale styles or broken hot-reload after pulling new
# changes, run:
#
#   npm run clean && npm run dev
#
# ─────────────────────────────────────────────────────────────────────────────
# Quick reference — which secrets gate which behavior:
#
#   TURSO_*     → durable subscriptions, API keys, alert rules
#   CRON_SECRET → /api/cron/* scheduled runs + /api/verify-payments
#   ADMIN_SECRET→ /api/admin/* (data-health, subscription overrides)
#   TAOSTATS    → fresh subnet data refresh
#   CMC         → TAO/USD fallback pricing
#   TAO_APP     → holder/validator snapshot scripts
#   OPENAI      → /api/chat (Explorer AI)
#
# Local read-only development works without any of the above; everything
# degrades gracefully to cached JSON + in-memory DB.
# ─────────────────────────────────────────────────────────────────────────────
