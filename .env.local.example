# ── TaoStats API ─────────────────────────────────────────────────────────────
#
# Obtain a key at: https://dash.taostats.io
#
TAOSTATS_API_KEY=your_taostats_api_key_here

# ── CoinMarketCap API ────────────────────────────────────────────────────────
#
# Free-tier key from https://coinmarketcap.com/api/
# Used as a secondary price source for TAO/USD when CoinGecko is unavailable,
# and as a market-data enrichment source (prices, volume, % changes) that
# does not depend on TaoStats.
#
CMC_API_KEY=your_coinmarketcap_api_key_here

# ── Dev stability note ────────────────────────────────────────────────────────
#
# If the dev server shows stale styles or broken hot-reload after pulling
# new changes, run:
#
#   npm run clean && npm run dev
